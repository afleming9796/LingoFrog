{
  "manifest_version": 3,
  "name": "LingoFrog",
  "version": "1.0.0",
  "description": "Local autocomplete powered by your own writing. No AI, no cloud — just your words, suggested back to you.",
  "permissions": ["storage", "activeTab"],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*",
        "https://docs.google.com/*",
        "https://www.linkedin.com/*",
        "https://slack.com/*",
        "https://app.slack.com/*"
      ],
      "js": ["trie.js", "content.js"],
      "css": ["lingofrog.css"]
    }
  ]
}